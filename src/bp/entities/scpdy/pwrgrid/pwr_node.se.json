{
	"format_version": "1.21.60",
	"minecraft:entity": {
		"description": {
			"identifier": "lc:scpdy_pwr_node",
			"spawn_category": "misc",
			"is_spawnable": false,
			"is_summonable": true,
			"is_experimental": false,
			"properties": {
				"lc:is_powered": {
					"type": "bool",
					"default": false,
					"client_sync": true
				}
			}
		},
		"component_groups": {
			"script_update_timer:slow": {
				"minecraft:timer": {
					"looping": true,
					"randomInterval": true,
					"time": [2.25, 5.0],
					"time_down_event": {
						"event": "pwr_node:script_update",
						"target": "self"
					}
				}
			},
			"script_update_timer:moderate": {
				"minecraft:timer": {
					"looping": true,
					"randomInterval": true,
					"time": [1.5, 4.0],
					"time_down_event": {
						"event": "pwr_node:script_update",
						"target": "self"
					}
				}
			},
			"script_update_timer:normal": {
				"minecraft:timer": {
					"looping": true,
					"randomInterval": true,
					"time": [0.75, 2.5],
					"time_down_event": {
						"event": "pwr_node:script_update",
						"target": "self"
					}
				}
			}
		},
		"components": {
			"minecraft:knockback_resistance": {
				"value": 1.0
			},
			"minecraft:type_family": {
				"family": ["inanimate", "pwrgrid", "pwr_src_or_node", "pwr_node"]
			},
			"minecraft:health": {
				"value": 1,
				"max": 1
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"on_damage": {
							"filters": {
								"test": "is_family",
								"subject": "other",
								"value": "player"
							}
						},
						"cause": "entity_attack",
						"deals_damage": "yes"
					},
					{
						"cause": "all",
						"deals_damage": "no"
					}
				]
			},
			"minecraft:breathable": {
				"breathes_solids": true,
				"breathes_water": true,
				"generates_bubbles": false
			},
			"minecraft:body_rotation_blocked": {},
			"minecraft:physics": {
				"has_collision": false,
				"has_gravity": false
			},
			"minecraft:pushable": {
				"is_pushable": false,
				"is_pushable_by_piston": false
			},
			"minecraft:collision_box": {
				"width": 0.7,
				"height": 0.9
			},
			"minecraft:conditional_bandwidth_optimization": {
				"default_values": {
					"max_optimized_distance": 30.0,
					"max_dropped_ticks": 12,
					"use_motion_prediction_hints": false
				}
			}
		},
		"events": {
			"minecraft:entity_spawned": {
				"trigger": "pwr_node:set_script_update_timer:auto"
			},
			"pwr_node:script_update": {},
			"pwr_node:set_script_update_timer:auto": {},
			"pwr_node:set_script_update_timer:slow": {
				"remove": {
					"component_groups": ["script_update_timer:moderate", "script_update_timer:normal"]
				},
				"add": {
					"component_groups": ["script_update_timer:slow"]
				}
			},
			"pwr_node:set_script_update_timer:moderate": {
				"remove": {
					"component_groups": ["script_update_timer:slow", "script_update_timer:normal"]
				},
				"add": {
					"component_groups": ["script_update_timer:moderate"]
				}
			},
			"pwr_node:set_script_update_timer:normal": {
				"remove": {
					"component_groups": ["script_update_timer:slow", "script_update_timer:moderate"]
				},
				"add": {
					"component_groups": ["script_update_timer:normal"]
				}
			},
			"pwr_node:power_on": {
				"set_property": {
					"lc:is_powered": true
				}
			},
			"pwr_node:power_off": {
				"set_property": {
					"lc:is_powered": false
				}
			}
		}
	}
}
