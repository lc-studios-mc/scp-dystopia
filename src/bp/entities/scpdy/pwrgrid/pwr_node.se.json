{
	"format_version": "1.21.60",
	"minecraft:entity": {
		"description": {
			"identifier": "lc:scpdy_pwr_node",
			"spawn_category": "misc",
			"is_spawnable": false,
			"is_summonable": true,
			"is_experimental": false
		},
		"component_groups": {
			"inactive": {
				"minecraft:type_family": {
					"family": ["inanimate", "pwrgrid", "pwr_node"]
				}
			},
			"active": {
				"minecraft:type_family": {
					"family": ["inanimate", "pwrgrid", "pwr_node", "pwr_sender"]
				}
			}
		},
		"components": {
			"minecraft:knockback_resistance": {
				"value": 1.0
			},
			"minecraft:health": {
				"value": 20,
				"max": 20
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"cause": "all",
						"deals_damage": "no"
					}
				]
			},
			"minecraft:breathable": {
				"breathes_solids": true,
				"breathes_water": true,
				"generates_bubbles": false
			},
			"minecraft:body_rotation_blocked": {},
			"minecraft:physics": {
				"has_collision": false,
				"has_gravity": false
			},
			"minecraft:pushable": {
				"is_pushable": false,
				"is_pushable_by_piston": false
			},
			"minecraft:custom_hit_test": {
				"hitboxes": [
					{
						"pivot": [0, 0.05, 0],
						"width": 0.8,
						"height": 0.8
					}
				]
			},
			"minecraft:collision_box": {
				"width": 0.1,
				"height": 0.1
			},
			"minecraft:conditional_bandwidth_optimization": {
				"default_values": {
					"max_optimized_distance": 30.0,
					"max_dropped_ticks": 12,
					"use_motion_prediction_hints": false
				}
			}
		},
		"events": {
			"minecraft:entity_spawned": {
				"add": {
					"component_groups": ["inactive"]
				}
			},
			"pwr_node:become_active": {
				"remove": {
					"component_groups": ["inactive"]
				},
				"add": {
					"component_groups": ["active"]
				}
			},
			"pwr_node:become_inactive": {
				"remove": {
					"component_groups": ["active"]
				},
				"add": {
					"component_groups": ["inactive"]
				}
			}
		}
	}
}
