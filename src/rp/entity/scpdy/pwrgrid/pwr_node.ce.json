{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "lc:scpdy_pwr_node",
			"materials": {
				"default": "entity"
			},
			"textures": {
				"power_on": "textures/scpdy/pwrgrid/pwr_node_powered",
				"power_off": "textures/scpdy/pwrgrid/pwr_node_off"
			},
			"geometry": {
				"default": "geometry.scpdy_billboard"
			},
			"animations": {
				"anim.billboard": "animation.scpdy_billboard.rotation"
			},
			"scripts": {
				"scale": "1.0",
				"animate": ["anim.billboard"],
				"initialize": ["v.is_powered = false;"],
				"pre_animation": ["v.is_powered = q.property('lc:is_powered');"]
			},
			"render_controllers": ["controller.render.scpdy.pwrgrid_entity_billboard"]
		}
	}
}
